---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import WhatsAppButton from '../../components/WhatsAppButton.astro';
import Tag from '../../components/Tag.astro';
import Button from '../../components/Button.astro';
import IconCheck from '../../components/icons/IconCheck.astro';
import IconExternalLink from '../../components/icons/IconExternalLink.astro';
import IconPlay from '../../components/icons/IconPlay.astro';
import VideoModal from '../../components/VideoModal.astro';
import caseStudies from '../../data/case-studies.json';

export function getStaticPaths() {
  return caseStudies.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
---

<BaseLayout title={`${project.title} — Crivellaro`} description={project.subtitle}>
  <Header />
  <main id="main-content" class="pt-24 pb-20">
    <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Back link -->
      <a href="/#projects" class="inline-flex items-center gap-2 text-sm text-surface-muted hover:text-cyan-400 transition-colors mb-8">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M19 12H5" stroke-linecap="round" /><path d="m12 19-7-7 7-7" stroke-linecap="round" stroke-linejoin="round" /></svg>
        Back to projects
      </a>

      <!-- Hero -->
      <div class="mb-12">
        <div class="flex flex-wrap gap-2 mb-4">
          {project.tags.map((tag: string) => <Tag>{tag}</Tag>)}
        </div>
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-surface-text mb-4">
          {project.title}
        </h1>
        <p class="text-xl text-surface-muted">{project.subtitle}</p>

        <!-- Meta bar -->
        <div class="flex flex-wrap gap-6 mt-6 text-sm text-surface-muted">
          <div><span class="text-surface-text font-medium">Client:</span> {project.client}</div>
          <div><span class="text-surface-text font-medium">Industry:</span> {project.industry}</div>
          <div><span class="text-surface-text font-medium">Timeline:</span> {project.timeline}</div>
        </div>

        <!-- Action buttons -->
        <div class="flex gap-3 mt-6">
          {project.liveUrl && (
            <Button href={project.liveUrl} variant="primary">
              <IconExternalLink class="w-4 h-4" />
              Live Demo
            </Button>
          )}
          {project.videoUrl && (
            <button
              type="button"
              class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl font-semibold text-sm transition-all duration-300 border-2 border-purple-500/50 text-purple-400 hover:bg-purple-500/10 hover:border-purple-400 cursor-pointer btn-hover"
              data-video-url={project.videoUrl}
            >
              <IconPlay class="w-4 h-4" />
              Watch Demo
            </button>
          )}
        </div>
      </div>

      <!-- Project image -->
      <div class="rounded-2xl overflow-hidden border border-surface-700 mb-12">
        <img
          src={project.image}
          alt={`${project.title} screenshot`}
          class="w-full aspect-video object-cover"
        />
      </div>

      <!-- Results grid -->
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-12">
        {project.results.map((r: { metric: string; label: string }) => (
          <div class="card-base p-4 text-center">
            <p class="text-2xl sm:text-3xl font-bold gradient-text">{r.metric}</p>
            <p class="text-xs sm:text-sm text-surface-muted mt-1">{r.label}</p>
          </div>
        ))}
      </div>

      <!-- Problem -->
      <section class="mb-10">
        <h2 class="text-2xl font-bold text-surface-text mb-4">The Problem</h2>
        <p class="text-surface-muted leading-relaxed">{project.problem}</p>
      </section>

      <!-- Approach -->
      <section class="mb-10">
        <h2 class="text-2xl font-bold text-surface-text mb-4">The Approach</h2>
        <ol class="space-y-4">
          {project.approach.map((step: string, i: number) => (
            <li class="flex gap-4">
              <span class="w-8 h-8 rounded-full bg-cyan-500/10 border border-cyan-500/30 flex items-center justify-center text-cyan-400 text-sm font-bold shrink-0">
                {i + 1}
              </span>
              <p class="text-surface-muted leading-relaxed pt-1">{step}</p>
            </li>
          ))}
        </ol>
      </section>

      <!-- Tech stack -->
      <section class="mb-10">
        <h2 class="text-2xl font-bold text-surface-text mb-4">Tech Stack</h2>
        <div class="flex flex-wrap gap-2">
          {project.techStack.map((tech: string) => <Tag>{tech}</Tag>)}
        </div>
      </section>

      <!-- Testimonial -->
      {project.testimonial && (
        <section class="mb-12">
          <blockquote class="card-base p-6 sm:p-8 border-l-4 border-l-cyan-500">
            <svg class="w-8 h-8 text-cyan-500/30 mb-3" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10H0z" />
            </svg>
            <p class="text-surface-muted leading-relaxed mb-4">"{project.testimonial.quote}"</p>
            <footer class="text-sm">
              <cite class="not-italic font-semibold text-surface-text">{project.testimonial.name}</cite>
              <span class="text-surface-muted"> — {project.testimonial.role}</span>
            </footer>
          </blockquote>
        </section>
      )}

      <!-- CTA -->
      <div class="card-base p-8 text-center bg-gradient-to-br from-cyan-500/5 to-purple-500/5">
        <h2 class="text-2xl font-bold text-surface-text mb-3">Want similar results?</h2>
        <p class="text-surface-muted mb-6 max-w-md mx-auto">Let's talk about how I can build an AI solution tailored to your business.</p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
          <Button href="/#contact" variant="primary">Get in Touch</Button>
          <Button href="/#pricing" variant="secondary">View Pricing</Button>
        </div>
      </div>
    </article>
  </main>
  <Footer />
  <WhatsAppButton />
  <VideoModal />
</BaseLayout>
