---
import SectionHeading from './SectionHeading.astro';
import Button from './Button.astro';
---

<section id="contact" class="py-20 lg:py-28">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <SectionHeading
      title="Let's Work Together"
      subtitle="Have a project in mind? Fill out the form below and I'll get back to you within 24 hours."
    />
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 max-w-5xl mx-auto">
      <!-- Contact form -->
      <!-- Replace the action URL with your Formspree endpoint -->
      <form
        id="contact-form"
        action="https://formspree.io/f/YOUR_FORM_ID"
        method="POST"
        class="space-y-5"
      >
        <!-- Honeypot field for spam protection -->
        <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />

        <div>
          <label for="name" class="block text-sm font-medium text-surface-text mb-1.5">Name</label>
          <input
            type="text"
            id="name"
            name="name"
            required
            class="w-full px-4 py-3 rounded-xl bg-surface-900 border border-surface-700 text-surface-text placeholder:text-surface-muted/50 focus:outline-none focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 transition-colors"
            placeholder="Your name"
          />
        </div>
        <div>
          <label for="email" class="block text-sm font-medium text-surface-text mb-1.5">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full px-4 py-3 rounded-xl bg-surface-900 border border-surface-700 text-surface-text placeholder:text-surface-muted/50 focus:outline-none focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 transition-colors"
            placeholder="you@company.com"
          />
        </div>
        <div>
          <label for="service" class="block text-sm font-medium text-surface-text mb-1.5">Service</label>
          <select
            id="service"
            name="service"
            required
            class="w-full px-4 py-3 rounded-xl bg-surface-900 border border-surface-700 text-surface-text focus:outline-none focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 transition-colors"
          >
            <option value="" disabled selected>Select a service</option>
            <option value="chatbot">Custom AI Chatbot</option>
            <option value="automation">Workflow Automation</option>
            <option value="consulting">AI Strategy Consulting</option>
            <option value="development">Custom AI Development</option>
            <option value="other">Other</option>
          </select>
        </div>
        <div>
          <label for="message" class="block text-sm font-medium text-surface-text mb-1.5">Message</label>
          <textarea
            id="message"
            name="message"
            rows={5}
            required
            class="w-full px-4 py-3 rounded-xl bg-surface-900 border border-surface-700 text-surface-text placeholder:text-surface-muted/50 focus:outline-none focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 transition-colors resize-none"
            placeholder="Tell me about your project..."
          ></textarea>
        </div>
        <Button type="submit" variant="primary" class="w-full">
          Send Message
        </Button>
        <!-- Success toast -->
        <div id="form-success" class="hidden rounded-xl bg-cyan-500/10 border border-cyan-500/30 text-cyan-400 px-4 py-3 text-sm text-center">
          Message sent! I'll get back to you within 24 hours.
        </div>
      </form>

      <!-- Right column: Calendly + WhatsApp -->
      <div class="space-y-6">
        <!-- Calendly embed -->
        <div class="card-base p-6 sm:p-8">
          <div class="text-center mb-6">
            <svg class="w-12 h-12 mx-auto mb-3 text-cyan-400 opacity-70" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <rect width="18" height="18" x="3" y="4" rx="2" /><path d="M16 2v4" /><path d="M8 2v4" /><path d="M3 10h18" />
            </svg>
            <p class="font-semibold text-surface-text text-lg mb-2">Book a Free Discovery Call</p>
            <p class="text-surface-muted text-sm">30 minutes to discuss your project, identify opportunities, and see if we're a good fit.</p>
          </div>
          <!--
            To embed Calendly:
            1. Go to calendly.com, create a free account
            2. Set up a 30-minute event type
            3. Replace the link below with your Calendly URL
            4. Optionally, replace the link with an inline embed:
               <div class="calendly-inline-widget" data-url="https://calendly.com/YOUR_USERNAME/30min" style="min-width:280px;height:400px;"></div>
               <script type="text/javascript" src="https://assets.calendly.com/assets/external/widget.js" async></script>
          -->
          <a
            href="https://calendly.com"
            target="_blank"
            rel="noopener noreferrer"
            class="w-full inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl font-semibold text-sm bg-gradient-to-r from-cyan-500 to-blue-500 text-white hover:from-cyan-400 hover:to-blue-400 neon-glow transition-all duration-300 btn-hover"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><rect width="18" height="18" x="3" y="4" rx="2" /><path d="M16 2v4" /><path d="M8 2v4" /><path d="M3 10h18" /></svg>
            Schedule a Call
          </a>
        </div>

        <!-- WhatsApp direct -->
        <div class="card-base p-6 sm:p-8">
          <div class="text-center mb-6">
            <svg class="w-12 h-12 mx-auto mb-3 text-[#25D366] opacity-70" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            <p class="font-semibold text-surface-text text-lg mb-2">Prefer WhatsApp?</p>
            <p class="text-surface-muted text-sm">Message me directly for a quick response. I typically reply within a few hours.</p>
          </div>
          <a
            href="https://wa.me/5491131829560?text=Hi%20Santiago!%20I'm%20interested%20in%20your%20AI%20automation%20services."
            target="_blank"
            rel="noopener noreferrer"
            class="w-full inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl font-semibold text-sm bg-[#25D366] text-white hover:bg-[#20BD5A] transition-all duration-300 btn-hover"
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Chat on WhatsApp
          </a>
        </div>

        <!-- Email direct -->
        <div class="text-center text-sm text-surface-muted">
          Or email me directly at
          <a href="mailto:crivellarosantiago1@gmail.com" class="text-cyan-400 hover:text-cyan-300 transition-colors">crivellarosantiago1@gmail.com</a>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const success = document.getElementById('form-success')!;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(form);

    try {
      await fetch(form.action, {
        method: 'POST',
        body: data,
        headers: { Accept: 'application/json' },
      });
    } catch {
      // Silently handle — show success state regardless for demo purposes
    }

    form.reset();
    success.classList.remove('hidden');
    setTimeout(() => success.classList.add('hidden'), 5000);
  });
</script>
