<!-- Single video modal instance for entire page -->
<div
  id="video-modal"
  class="fixed inset-0 z-[60] flex items-center justify-center bg-surface-950/90 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300"
  role="dialog"
  aria-modal="true"
  aria-label="Video player"
  aria-hidden="true"
>
  <div class="relative w-full max-w-4xl mx-4">
    <button
      type="button"
      id="video-modal-close"
      class="absolute -top-12 right-0 text-surface-muted hover:text-white transition-colors p-2 cursor-pointer"
      aria-label="Close video"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
        <path d="M18 6 6 18" stroke-linecap="round" stroke-linejoin="round" /><path d="m6 6 12 12" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </button>
    <div class="aspect-video rounded-xl overflow-hidden bg-surface-900">
      <iframe
        id="video-modal-iframe"
        class="w-full h-full"
        src=""
        title="Project demo video"
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
      ></iframe>
    </div>
  </div>
</div>

<script>
  const modal = document.getElementById('video-modal')!;
  const iframe = document.getElementById('video-modal-iframe') as HTMLIFrameElement;
  const closeBtn = document.getElementById('video-modal-close')!;

  function openModal(url: string) {
    iframe.src = url;
    modal.classList.remove('opacity-0', 'pointer-events-none');
    modal.setAttribute('aria-hidden', 'false');
    closeBtn.focus();
  }

  function closeModal() {
    modal.classList.add('opacity-0', 'pointer-events-none');
    modal.setAttribute('aria-hidden', 'true');
    iframe.src = '';
  }

  document.addEventListener('click', (e) => {
    const btn = (e.target as Element).closest('[data-video-url]') as HTMLElement | null;
    if (btn) openModal(btn.dataset.videoUrl!);
  });

  closeBtn.addEventListener('click', closeModal);
  modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });
</script>
