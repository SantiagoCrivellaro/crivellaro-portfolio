---
import SectionHeading from './SectionHeading.astro';
import ServiceCard from './ServiceCard.astro';
import IconBot from './icons/IconBot.astro';
import IconBrain from './icons/IconBrain.astro';
import IconAutomation from './icons/IconAutomation.astro';
import IconCode from './icons/IconCode.astro';
import services from '../data/services.json';

const iconMap: Record<string, any> = {
  bot: IconBot,
  brain: IconBrain,
  automation: IconAutomation,
  code: IconCode,
};
---

<section id="services" class="py-20 lg:py-28">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <SectionHeading
      title="What I Do"
      subtitle="Specialized AI automation services designed to give your business a competitive edge."
    />
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {services.map((service) => (
        <ServiceCard
          title={service.title}
          description={service.description}
          Icon={iconMap[service.icon]}
        />
      ))}
    </div>
  </div>
</section>
