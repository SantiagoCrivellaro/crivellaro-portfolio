---
interface Props {
  title: string;
  subtitle?: string;
  id?: string;
}

const { title, subtitle, id } = Astro.props;
---

<div class="text-center mb-12 lg:mb-16" id={id}>
  <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold gradient-text mb-4">
    {title}
  </h2>
  {subtitle && (
    <p class="text-surface-muted text-lg max-w-2xl mx-auto">
      {subtitle}
    </p>
  )}
</div>
