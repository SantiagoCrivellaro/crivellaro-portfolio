---
import SectionHeading from './SectionHeading.astro';
import IconGithub from './icons/IconGithub.astro';
import IconMail from './icons/IconMail.astro';
---

<section id="about" class="py-20 lg:py-28 bg-surface-900/50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Photo -->
      <div class="scroll-animate flex justify-center lg:justify-end">
        <div class="relative">
          <div class="w-64 h-64 sm:w-80 sm:h-80 rounded-2xl overflow-hidden border-2 border-surface-700 relative z-10">
            <img src="/177893287.jpg" alt="Santiago Crivellaro" class="w-full h-full object-cover" />
          </div>
          <!-- Decorative border offset -->
          <div class="absolute -bottom-3 -right-3 w-64 h-64 sm:w-80 sm:h-80 rounded-2xl border-2 border-cyan-500/20 z-0" aria-hidden="true"></div>
        </div>
      </div>

      <!-- Bio -->
      <div class="scroll-animate">
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold gradient-text mb-6">
          Hey, I'm Santiago
        </h2>
        <div class="space-y-4 text-surface-muted leading-relaxed">
          <p>
            I'm an AI automation specialist based in Argentina. I help businesses eliminate repetitive work and unlock new capabilities by building custom AI solutions — from intelligent chatbots to end-to-end workflow automation.
          </p>
          <p>
            My approach is simple: understand your business deeply, identify the highest-impact opportunities for AI, and build solutions that actually work in production — not just in demos.
          </p>
          <p>
            Whether you need a GPT-powered customer support bot, an automated lead qualification pipeline, or a custom AI tool built from scratch, I'll work closely with you from discovery to deployment.
          </p>
        </div>

        <div class="mt-8 flex flex-wrap gap-4">
          <a
            href="https://github.com/SantiagoCrivellaro"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-sm text-surface-muted hover:text-cyan-400 transition-colors"
          >
            <IconGithub class="w-5 h-5" />
            GitHub
          </a>
          <a
            href="mailto:crivellarosantiago1@gmail.com"
            class="inline-flex items-center gap-2 text-sm text-surface-muted hover:text-cyan-400 transition-colors"
          >
            <IconMail class="w-5 h-5" />
            crivellarosantiago1@gmail.com
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
